# ─── Meal Planner — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# ── Auth ────────────────────────────────────────────────────────────────────
# Password required to access the app.
# Leave empty (or remove entirely) for open access during local development.
VITE_APP_PASSWORD=

# ── Supabase (Phase 3 — uncomment when ready to deploy shared sync) ─────────
# Create a free project at https://supabase.com
# Then enable the storage adapter in src/store/storage.js
# VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-here
